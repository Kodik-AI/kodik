{
  "mcpServers": {
    "telegram": {
      "command": "bun",
      "args": ["run", "--cwd", "${KODIK_PLUGIN_ROOT}", "--shell=bun", "--silent", "start"],
      "env": {
        "TELEGRAM_BOT_TOKEN": "${user_config.bot_token}",
        "TELEGRAM_ACCESS_MODE": "${user_config.access_mode}",
        "TELEGRAM_STATE_DIR": "${user_config.state_dir}"
      }
    }
  }
}
