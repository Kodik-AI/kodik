{
  "servers": {
    "notion": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@notionhq/notion-mcp-server"
      ],
      "env": {
        "NOTION_API_KEY": "${env:NOTION_API_KEY}"
      },
      "disabled": true
    }
  },
  "meta": {
    "notion": {
      "id": "notion-mcp",
      "title": "notion",
      "description": "Community MCP server for notion. Set the required env vars and flip disabled to false."
    }
  }
}
