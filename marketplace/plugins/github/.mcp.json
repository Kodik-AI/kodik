{
  "servers": {
    "github": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${user_config.personal_access_token}"
      }
    }
  },
  "meta": {
    "github": {
      "id": "github-mcp",
      "title": "github",
      "description": "Community MCP server for github. Sign in with a personal access token at https://github.com/settings/tokens."
    }
  }
}
